{
  "info": {
    "name": "Formula 1 API",
    "description": "Colección CRUD completa para el Sistema de Estadísticas Formula 1\nBase URL: http://localhost:8080/api\n\nEntidades:\n- Pilotos\n- Escuderías\n- Temporadas\n- Circuitos\n- Grandes Premios",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Pilotos",
      "description": "CRUD para la entidad PILOTO. La PK es compuesta (tipoDocumento + numDocumento).",
      "item": [
        {
          "name": "GET - Listar todos los pilotos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pilotos?page=0&size=20&search=",
              "host": ["{{baseUrl}}"],
              "path": ["pilotos"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "search", "value": "", "description": "Filtrar por nombre, apellidos o alias" }
              ]
            },
            "description": "Retorna lista paginada de pilotos. Parámetros opcionales: page, size, search."
          }
        },
        {
          "name": "GET - Obtener piloto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pilotos/PASAPORTE/NL-VER-001",
              "host": ["{{baseUrl}}"],
              "path": ["pilotos", "PASAPORTE", "NL-VER-001"]
            },
            "description": "Obtener un piloto por su tipo de documento y número de documento.\nEjemplos de IDs del seed:\n- PASAPORTE / NL-VER-001  (Max Verstappen)\n- PASAPORTE / ES-ALO-001  (Fernando Alonso)\n- PASAPORTE / GB-HAM-001  (Lewis Hamilton)\n- PASAPORTE / MX-PER-001  (Sergio Pérez)"
          }
        },
        {
          "name": "POST - Crear piloto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoDocumento\": \"PASAPORTE\",\n  \"numDocumento\": \"AU-RIC-001\",\n  \"nombre\": \"Daniel\",\n  \"apellidos\": \"Ricciardo\",\n  \"nacionalidad\": \"Australiana\",\n  \"fechaNacimiento\": \"1989-07-01\",\n  \"alias\": \"RIC\",\n  \"numParrillaPermanente\": 3,\n  \"urlFoto\": null,\n  \"estado\": \"ACTIVO\",\n  \"temporadaRetiro\": null,\n  \"escuderiaId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pilotos",
              "host": ["{{baseUrl}}"],
              "path": ["pilotos"]
            },
            "description": "Crear un nuevo piloto. Se crea también la Persona asociada.\nCampos obligatorios: tipoDocumento, numDocumento, nombre, apellidos.\nEstados válidos: ACTIVO, RETIRADO, SUSPENDIDO, INACTIVO."
          }
        },
        {
          "name": "PUT - Actualizar piloto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipoDocumento\": \"PASAPORTE\",\n  \"numDocumento\": \"NL-VER-001\",\n  \"nombre\": \"Max\",\n  \"apellidos\": \"Verstappen\",\n  \"nacionalidad\": \"Neerlandesa\",\n  \"fechaNacimiento\": \"1997-09-30\",\n  \"alias\": \"MAX\",\n  \"numParrillaPermanente\": 1,\n  \"urlFoto\": null,\n  \"estado\": \"ACTIVO\",\n  \"temporadaRetiro\": null,\n  \"escuderiaId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pilotos/PASAPORTE/NL-VER-001",
              "host": ["{{baseUrl}}"],
              "path": ["pilotos", "PASAPORTE", "NL-VER-001"]
            },
            "description": "Actualizar datos de un piloto existente."
          }
        },
        {
          "name": "DELETE - Eliminar piloto",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pilotos/PASAPORTE/AU-RIC-001",
              "host": ["{{baseUrl}}"],
              "path": ["pilotos", "PASAPORTE", "AU-RIC-001"]
            },
            "description": "Eliminar un piloto por tipo y número de documento."
          }
        }
      ]
    },
    {
